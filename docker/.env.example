# ─────────────────────────────────────────────
# PicoClaw Docker Configuration
# Kopieer naar ../.env (project root) en pas aan
# ─────────────────────────────────────────────

# Pad naar memory vault op de host (bind mount)
# Dit maakt het vault beschikbaar buiten de container
MEMORY_VAULT_PATH=./data/memory

# ─────────────────────────────────────────────
# Clawd-Crawlee (Deep Scraper)
# ─────────────────────────────────────────────

# Host port voor debugging (0 = niet exposen)
CRAWLEE_HOST_PORT=3000

# Max gelijktijdige browser tabs
CRAWLEE_MAX_CONCURRENCY=5

# Timeout per pagina in milliseconden
CRAWLEE_REQUEST_TIMEOUT_MS=60000

# Log level: error, warning, info, debug
CRAWLEE_LOG_LEVEL=info
